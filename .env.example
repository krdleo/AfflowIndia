# ─── Runtime ──────────────────────────────────────────────────
# "development" locally, "production" on Railway
NODE_ENV="development"
# Port the server listens on (Railway injects this automatically)
PORT="3000"

# ─── Database (PostgreSQL in prod, SQLite for dev is also OK) ─
# Prod: postgresql://user:password@host:5432/afflow?schema=public&connection_limit=20&pool_timeout=10
# Dev:  file:./prisma/dev.sqlite
DATABASE_URL="postgresql://user:password@localhost:5432/afflow?schema=public&connection_limit=20&pool_timeout=10"

# ─── Shopify App ──────────────────────────────────────────────
# From Partner Dashboard → Apps → AfflowIndia → API credentials
SHOPIFY_API_KEY=""
SHOPIFY_API_SECRET=""
# Public URL of the deployed app (production: https://afflow.in)
SHOPIFY_APP_URL="https://www.afflow.in"
# Must match shopify.app.toml access_scopes.scopes
SCOPES="read_orders,write_discounts,write_app_proxy"
# Set to "true" to use Shopify's real billing API. Leave unset/false for
# dev-store test charges.
SHOPIFY_APP_LIVE="false"
# Optional — set if the merchant uses a custom storefront domain
SHOP_CUSTOM_DOMAIN=""

# ─── Encryption (AES-256-GCM for PII and Shopify tokens) ──────
# 32-byte hex key. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=""

# ─── JWT (Affiliate Portal Auth) ──────────────────────────────
# Secret for signing affiliate portal JWTs (min 32 chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=""

# ─── Email (Resend) ───────────────────────────────────────────
RESEND_API_KEY=""
# Must be a domain verified in the Resend dashboard in production.
# If unset, the app falls back to "noreply@afflow.in" and logs a warning.
EMAIL_FROM="noreply@afflow.in"

# ─── Razorpay X (Auto-Payouts — Premium plan only) ────────────
# Global keys for the Afflow platform account. Per-shop Razorpay keys are
# entered in the admin UI and stored encrypted on the Shop record, so these
# env vars may remain blank in deployments that do not use a platform-owned
# Razorpay account.
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
