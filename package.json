    "eslint-plugin-react-hooks": "^4.6.2",
    "graphql-config": "^5.1.1",
    "postcss": "^8.5.9",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.3"
