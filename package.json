    "@tailwindcss/vite": "^4.2.2",
    "@types/bcryptjs": "^3.0.0",
    "@types/eslint": "^9.6.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.2",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.3.25",
    "@types/react-dom": "^18.3.7",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
